<clickhouse>
    <!-- Async inserts (default desde 26.3 LTS): batching automático de inserts -->
    <async_insert>1</async_insert>
    <wait_for_async_insert>1</wait_for_async_insert>
    <async_insert_max_data_size>10485760</async_insert_max_data_size>
    <async_insert_busy_timeout_ms>1000</async_insert_busy_timeout_ms>

    <!-- Memoria dinámica: deja headroom para otros procesos del host -->
    <max_server_memory_usage_to_ram_ratio>0.8</max_server_memory_usage_to_ram_ratio>

    <!-- Compresión por defecto en disco -->
    <compression>
        <case>
            <method>zstd</method>
            <level>3</level>
        </case>
    </compression>

    <!-- MergeTree -->
    <merge_tree>
        <max_suspicious_broken_parts>10</max_suspicious_broken_parts>
        <parts_to_delay_insert>500</parts_to_delay_insert>
        <parts_to_throw_insert>1500</parts_to_throw_insert>
    </merge_tree>

    <!-- Endpoint Prometheus para Grafana -->
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
    </prometheus>
</clickhouse>
