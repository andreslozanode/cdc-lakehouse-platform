{
  "name": "pg-oltp-source",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",

    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "debezium",
    "database.password": "change_me_cdc",
    "database.dbname": "oltp",
    "topic.prefix": "oltp",

    "plugin.name": "pgoutput",
    "publication.name": "dbz_publication",
    "publication.autocreate.mode": "disabled",
    "slot.name": "dbz_slot",

    "table.include.list": "public.customers,public.products,public.orders,public.order_items",
    "schema.include.list": "public",

    "snapshot.mode": "initial",
    "incremental.snapshot.chunk.size": "8192",
    "signal.data.collection": "public.debezium_signal",
    "signal.enabled.channels": "source",

    "heartbeat.interval.ms": "10000",
    "heartbeat.action.query": "UPDATE public.debezium_signal SET data = now()::text WHERE id = 'hb'",

    "decimal.handling.mode": "precise",
    "time.precision.mode": "adaptive_time_microseconds",
    "tombstones.on.delete": "false",

    "_comment_format": "Envelope COMPLETO (before/after/op). Flink lo lee con format='debezium-avro-confluent' => changelog nativo (+I/-U/+U/-D). NO se aplica ExtractNewRecordState a propósito.",

    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",

    "topic.creation.enable": "true",
    "topic.creation.default.replication.factor": "1",
    "topic.creation.default.partitions": "12",
    "topic.creation.default.compression.type": "zstd",
    "topic.creation.default.cleanup.policy": "delete",
    "topic.creation.default.retention.ms": "604800000",

    "producer.override.compression.type": "zstd",
    "producer.override.linger.ms": "50",
    "producer.override.batch.size": "131072",

    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "_dlq.pg-oltp-source",
    "errors.deadletterqueue.context.headers.enable": "true",
    "errors.log.enable": "true"
  }
}
